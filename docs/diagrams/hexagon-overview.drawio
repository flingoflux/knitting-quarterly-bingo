<mxfile host="app.diagrams.net">
  <diagram name="Gesamtsystem-Hexagon">
    <mxGraphModel dx="1200" dy="800" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1100" pageHeight="700" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Titel -->
        <mxCell id="title" value="Gesamtsystem – Hexagonale Architektur" style="text;html=1;fontSize=16;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="200" y="20" width="680" height="30" as="geometry" />
        </mxCell>

        <!-- === PRIMARY ADAPTER (links) === -->
        <mxCell id="pri-bg" value="Primary Adapter" style="swimlane;startSize=25;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="20" y="70" width="170" height="280" as="geometry" />
        </mxCell>
        <mxCell id="ui" value="UI Components&#xa;Pages / Dialogs" style="rounded=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="pri-bg">
          <mxGeometry x="15" y="100" width="140" height="50" as="geometry" />
        </mxCell>

        <!-- === HEXAGON (mitte) === -->
        <mxCell id="hex-bg" value="Application Hexagon" style="swimlane;startSize=25;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="220" y="70" width="300" height="280" as="geometry" />
        </mxCell>
        <mxCell id="inports" value="&lt;&lt;InPorts&gt;&gt;" style="shape=parallelogram;perimeter=parallelogramPerimeter;fixedSize=1;size=10;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="hex-bg">
          <mxGeometry x="15" y="60" width="130" height="50" as="geometry" />
        </mxCell>
        <mxCell id="core" value="UseCases + Domain Model" style="shape=hexagon;perimeter=hexagonPerimeter2;fixedSize=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;fontStyle=1;" vertex="1" parent="hex-bg">
          <mxGeometry x="75" y="125" width="150" height="70" as="geometry" />
        </mxCell>
        <mxCell id="outports" value="&lt;&lt;OutPorts&gt;&gt;" style="shape=parallelogram;perimeter=parallelogramPerimeter;fixedSize=1;size=10;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="hex-bg">
          <mxGeometry x="155" y="210" width="130" height="50" as="geometry" />
        </mxCell>
        <!-- Pfeile im Hexagon -->
        <mxCell id="e-in-core" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="inports" target="core" parent="hex-bg">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-core-out" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="core" target="outports" parent="hex-bg">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- === SECONDARY ADAPTER (rechts) === -->
        <mxCell id="sec-bg" value="Secondary Adapter" style="swimlane;startSize=25;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="550" y="70" width="180" height="280" as="geometry" />
        </mxCell>
        <mxCell id="ls-adapter" value="LocalStorage&#xa;Adapter" style="rounded=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=10;" vertex="1" parent="sec-bg">
          <mxGeometry x="20" y="70" width="140" height="50" as="geometry" />
        </mxCell>
        <mxCell id="idb-adapter" value="IndexedDB&#xa;Adapter" style="rounded=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=10;" vertex="1" parent="sec-bg">
          <mxGeometry x="20" y="140" width="140" height="50" as="geometry" />
        </mxCell>

        <!-- Browser APIs -->
        <mxCell id="infra" value="Browser APIs&#xa;(LocalStorage / IndexedDB)" style="shape=cylinder3;whiteSpace=wrap;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="575" y="390" width="140" height="60" as="geometry" />
        </mxCell>

        <!-- === EXTERNE PFEILE === -->
        <!-- UI -> InPorts -->
        <mxCell id="e-ui-in" value="calls" style="edgeStyle=orthogonalEdgeStyle;fontSize=9;" edge="1" source="ui" target="inports" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- LS implements OutPorts -->
        <mxCell id="e-ls-out" value="implements" style="edgeStyle=orthogonalEdgeStyle;dashed=1;fontSize=9;endArrow=open;endFill=0;" edge="1" source="ls-adapter" target="outports" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- IDB implements OutPorts -->
        <mxCell id="e-idb-out" value="implements" style="edgeStyle=orthogonalEdgeStyle;dashed=1;fontSize=9;endArrow=open;endFill=0;" edge="1" source="idb-adapter" target="outports" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- LS -> Infra -->
        <mxCell id="e-ls-infra" style="edgeStyle=orthogonalEdgeStyle;fontSize=9;" edge="1" source="ls-adapter" target="infra" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- IDB -> Infra -->
        <mxCell id="e-idb-infra" style="edgeStyle=orthogonalEdgeStyle;fontSize=9;" edge="1" source="idb-adapter" target="infra" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Legende -->
        <mxCell id="legend" value="Abhaengigkeitsregel: Hexagon kennt keine Adapter. Adapter haengen von Ports ab." style="text;html=1;fontSize=9;fontStyle=2;align=center;" vertex="1" parent="1">
          <mxGeometry x="150" y="490" width="680" height="20" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
